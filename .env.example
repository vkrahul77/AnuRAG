# AnuRAG Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# LLM PROVIDER — Switch between Gemini and Claude!
# =============================================================================
# Options: "gemini" (default) or "claude"
# Database, embeddings, and search are UNAFFECTED by this setting.
LLM_PROVIDER=gemini

# =============================================================================
# GOOGLE GEMINI CONFIGURATION
# =============================================================================

# Required when LLM_PROVIDER=gemini (also needed for embeddings in any mode)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Alternative name for Gemini API key
# GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# ANTHROPIC CLAUDE CONFIGURATION
# =============================================================================

# Required when LLM_PROVIDER=claude
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude Chat Model — Choose one:
#   claude-sonnet-4-20250514  (RECOMMENDED: best cost/intelligence)
#   claude-opus-4-20250514    (maximum reasoning power, 5x cost)
#   claude-3-5-haiku-latest   (fast & cheap)
CLAUDE_CHAT_MODEL=claude-sonnet-4-20250514

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

# Chat/Reasoning Model (for Gemini) - Choose one:
#   gemini-2.0-flash      (default - fast, cheap, good quality)
#   gemini-2.0-flash-lite (faster, cheaper, lower quality)
#   gemini-1.5-flash      (older but stable)
#   gemini-1.5-pro        (best quality, slower, 10x more expensive)
#   gemini-2.0-pro        (newest pro model)
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Embedding Model (for vector search)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# =============================================================================
# LOCAL EMBEDDINGS (Recommended to avoid rate limits!)
# =============================================================================

# Set to "true" to use local embeddings (FREE, no rate limits!)
USE_LOCAL_EMBEDDINGS=false

# Local model options:
#   all-MiniLM-L6-v2      (fast, 384 dimensions)
#   all-mpnet-base-v2     (better quality, 768 dimensions)
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# OTHER SETTINGS
# =============================================================================

# Optional: Cohere API Key for reranking
# Get your key from: https://dashboard.cohere.ai/api-keys
# COHERE_API_KEY=your_cohere_api_key_here

# Optional: Elasticsearch URL (default: http://localhost:9200)
# ELASTICSEARCH_URL=http://localhost:9200

# API delay in seconds (for rate limiting)
API_DELAY=4.0

# Agent settings
MAX_AGENT_TURNS=10
TEMPERATURE=0.0
MAX_OUTPUT_TOKENS=4096

# =============================================================================
# PATHS
# =============================================================================

# Path to your PDF papers directory
# PAPER_PATH=./papers

# Pygmid gm/ID look-up table files (for Stage 2 design-space exploration)
# LUT_NMOS_PATH=/path/to/your/nmos_lut.mat
# LUT_PMOS_PATH=/path/to/your/pmos_lut.mat
